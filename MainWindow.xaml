<Window x:Class="ClipMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipMaster"
        Width="480" Height="640"
        MinWidth="380" MinHeight="400"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="{StaticResource BgBrush}"
        Deactivated="Window_Deactivated"
        SizeChanged="Window_SizeChanged"
        KeyDown="Window_KeyDown">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="36"/>   <!-- Title bar -->
      <RowDefinition Height="Auto"/> <!-- Search + Paste Top -->
      <RowDefinition Height="Auto"/> <!-- Filter chips -->
      <RowDefinition Height="Auto"/> <!-- Tag filter chips -->
      <RowDefinition Height="Auto"/> <!-- Tab strip -->
      <RowDefinition Height="*"/>    <!-- Tab content -->
    </Grid.RowDefinitions>

    <!-- Title bar -->
    <Grid Grid.Row="0" Background="#111111"
          MouseLeftButtonDown="TitleBar_MouseDown">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="36"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="ClipMaster"
                 Foreground="{StaticResource Text1Brush}"
                 FontSize="13" FontWeight="SemiBold"
                 VerticalAlignment="Center" Margin="12,0,0,0"/>
      <Button Grid.Column="1" Content="✕"
              Background="Transparent" Foreground="{StaticResource Text2Brush}"
              BorderThickness="0" FontSize="14" Cursor="Hand"
              VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
              Click="CloseBtn_Click"/>
    </Grid>

    <!-- Search + Paste Top -->
    <Grid Grid.Row="1" Margin="8,8,8,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBox x:Name="SearchBox" Grid.Column="0"
               Background="#1e1e1e" Foreground="{StaticResource Text1Brush}"
               BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
               Padding="8,6" FontSize="13" CaretBrush="{StaticResource AccentBrush}"
               TextChanged="SearchBox_TextChanged" KeyDown="SearchBox_KeyDown">
        <TextBox.Template>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ScrollViewer x:Name="PART_ContentHost"/>
            </Border>
          </ControlTemplate>
        </TextBox.Template>
      </TextBox>
      <Button x:Name="PasteTopBtn" Grid.Column="1"
              Content="Paste Top" Margin="6,0,0,0"
              Style="{StaticResource PasteBtn}"
              Click="PasteTopBtn_Click"/>
    </Grid>

    <!-- Filter chips -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,6,8,0">
      <ToggleButton x:Name="FilterAll"       Content="All"       Tag="all"
                    Style="{StaticResource TabBtn}" IsChecked="True"
                    Checked="FilterChip_Checked" Margin="0,0,4,0"/>
      <ToggleButton x:Name="FilterPinned"    Content="Pinned"    Tag="pinned"
                    Style="{StaticResource TabBtn}"
                    Checked="FilterChip_Checked" Margin="0,0,4,0"/>
      <ToggleButton x:Name="FilterSensitive" Content="Sensitive" Tag="sensitive"
                    Style="{StaticResource TabBtn}"
                    Checked="FilterChip_Checked"/>
    </StackPanel>

    <!-- Tag filter chips (dynamic) -->
    <WrapPanel x:Name="TagFilterChips" Grid.Row="3" Margin="8,4,8,0"/>

    <!-- Tab strip -->
    <Border Grid.Row="4" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0" Margin="0,6,0,0">
      <StackPanel Orientation="Horizontal">
        <ToggleButton x:Name="TabStack"    Content="Stack"    Tag="stack"
                      Style="{StaticResource TabBtn}" IsChecked="True"
                      Checked="Tab_Checked"/>
        <ToggleButton x:Name="TabRules"    Content="Rules"    Tag="rules"
                      Style="{StaticResource TabBtn}" Checked="Tab_Checked"/>
        <ToggleButton x:Name="TabSettings" Content="Settings" Tag="settings"
                      Style="{StaticResource TabBtn}" Checked="Tab_Checked"/>
      </StackPanel>
    </Border>

    <!-- Tab content -->
    <Grid Grid.Row="5">

      <!-- Stack panel -->
      <ScrollViewer x:Name="StackScrollView" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="ClipList" Margin="8"/>
      </ScrollViewer>

      <!-- Rules panel -->
      <ScrollViewer x:Name="RulesScrollView" Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="RulesList" Margin="8">
          <Button x:Name="AddRuleBtn" Content="+ Add Rule"
                  Style="{StaticResource ActionBtn}"
                  HorizontalAlignment="Left" Margin="0,4,0,8"
                  Click="AddRule_Click"/>
        </StackPanel>
      </ScrollViewer>

      <!-- Settings panel -->
      <ScrollViewer x:Name="SettingsScrollView" Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="SettingsForm" Margin="12"/>
      </ScrollViewer>

    </Grid>

    <!-- Toast overlay -->
    <Border x:Name="ToastBorder"
            Grid.RowSpan="6"
            Background="#333333" CornerRadius="6" Padding="14,7"
            HorizontalAlignment="Center" VerticalAlignment="Bottom"
            Margin="0,0,0,16" Opacity="0" IsHitTestVisible="False">
      <TextBlock x:Name="ToastText" Foreground="White" FontSize="12"/>
    </Border>

  </Grid>
</Window>
