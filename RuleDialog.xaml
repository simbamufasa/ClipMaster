<Window x:Class="ClipMaster.RuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rule" Width="440" Height="520"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="NoResize" Background="#1a1a1a"
        WindowStartupLocation="CenterOwner" Topmost="True"
        KeyDown="Window_KeyDown">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- title -->
      <RowDefinition Height="Auto"/>  <!-- name -->
      <RowDefinition Height="Auto"/>  <!-- mode + flags -->
      <RowDefinition Height="Auto"/>  <!-- pattern -->
      <RowDefinition Height="Auto"/>  <!-- replacement -->
      <RowDefinition Height="*"/>     <!-- test -->
      <RowDefinition Height="Auto"/>  <!-- footer -->
    </Grid.RowDefinitions>

    <TextBlock x:Name="TitleLabel" Grid.Row="0" Text="New Rule"
               FontSize="15" FontWeight="SemiBold"
               Foreground="#f0f0f0" Margin="0,0,0,12"/>

    <StackPanel Grid.Row="1" Margin="0,0,0,8">
      <TextBlock Text="Rule Name" Foreground="#a0a0a0" FontSize="11" Margin="0,0,0,3"/>
      <TextBox x:Name="NameBox" Background="#1e1e1e" Foreground="#f0f0f0"
               BorderBrush="#333333" BorderThickness="1" Padding="7,5" FontSize="12"/>
    </StackPanel>

    <Grid Grid.Row="2" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="80"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Margin="0,0,8,0">
        <TextBlock Text="Mode" Foreground="#a0a0a0" FontSize="11" Margin="0,0,0,3"/>
        <ComboBox x:Name="ModeBox" FontSize="12">
          <ComboBoxItem Content="Auto (on copy)"    Tag="auto"   IsSelected="True"/>
          <ComboBoxItem Content="Manual (on demand)" Tag="manual"/>
        </ComboBox>
      </StackPanel>
      <StackPanel Grid.Column="1">
        <TextBlock Text="Flags" Foreground="#a0a0a0" FontSize="11" Margin="0,0,0,3"/>
        <TextBox x:Name="FlagsBox" Text="g" TextAlignment="Center"
                 Background="#1e1e1e" Foreground="#f0f0f0"
                 BorderBrush="#333333" BorderThickness="1" Padding="7,5" FontSize="12"/>
      </StackPanel>
    </Grid>

    <StackPanel Grid.Row="3" Margin="0,0,0,8">
      <TextBlock Text="Pattern (Regex)" Foreground="#a0a0a0" FontSize="11" Margin="0,0,0,3"/>
      <TextBox x:Name="PatternBox" FontFamily="Consolas"
               Background="#1e1e1e" Foreground="#f0f0f0"
               BorderBrush="#333333" BorderThickness="1" Padding="7,5" FontSize="12"
               TextChanged="LiveTest_Changed"/>
    </StackPanel>

    <StackPanel Grid.Row="4" Margin="0,0,0,8">
      <TextBlock Text="Replacement (blank = delete matches)" Foreground="#a0a0a0" FontSize="11" Margin="0,0,0,3"/>
      <TextBox x:Name="ReplacementBox" FontFamily="Consolas"
               Background="#1e1e1e" Foreground="#f0f0f0"
               BorderBrush="#333333" BorderThickness="1" Padding="7,5" FontSize="12"
               TextChanged="LiveTest_Changed"/>
    </StackPanel>

    <StackPanel Grid.Row="5" Margin="0,0,0,8">
      <TextBlock Text="Test input" Foreground="#a0a0a0" FontSize="11" Margin="0,0,0,3"/>
      <TextBox x:Name="TestBox" Height="60"
               Background="#1e1e1e" Foreground="#f0f0f0"
               BorderBrush="#333333" BorderThickness="1" Padding="7,5" FontSize="12"
               TextWrapping="Wrap" AcceptsReturn="True"
               TextChanged="LiveTest_Changed"/>
      <TextBlock x:Name="TestResult" FontFamily="Consolas" FontSize="11"
                 Margin="0,4,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
    </StackPanel>

    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" Background="#2a2a2a" Foreground="#a0a0a0"
              BorderBrush="#333333" BorderThickness="1" Padding="12,6"
              Click="Cancel_Click" Margin="0,0,8,0"/>
      <Button Content="Save Rule" Background="#7c6af7" Foreground="White"
              BorderThickness="0" Padding="12,6" Click="Save_Click"/>
    </StackPanel>
  </Grid>
</Window>
