<Window x:Class="ClipMaster.TagDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Tags" Width="320" Height="420"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="NoResize" Background="#1a1a1a"
        WindowStartupLocation="CenterOwner" Topmost="True"
        KeyDown="Window_KeyDown">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Manage Tags"
               FontSize="15" FontWeight="SemiBold"
               Foreground="#f0f0f0" Margin="0,0,0,12"/>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel x:Name="TagList"/>
    </ScrollViewer>

    <Grid Grid.Row="2" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBox x:Name="NewTagBox" Grid.Column="0"
               Background="#1e1e1e" Foreground="#f0f0f0"
               BorderBrush="#333333" BorderThickness="1"
               Padding="7,5" FontSize="12"
               KeyDown="NewTagBox_KeyDown"/>
      <Button Grid.Column="1" Content="Add" Margin="6,0,0,0"
              Background="#2a2a2a" Foreground="#a0a0a0"
              BorderBrush="#333333" BorderThickness="1"
              Padding="10,5" FontSize="11"
              Click="AddTagBtn_Click"/>
    </Grid>

    <StackPanel Grid.Row="3" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="Cancel" Background="#2a2a2a" Foreground="#a0a0a0"
              BorderBrush="#333333" BorderThickness="1" Padding="12,6"
              Click="Cancel_Click" Margin="0,0,8,0"/>
      <Button Content="Save" Background="#7c6af7" Foreground="White"
              BorderThickness="0" Padding="12,6" Click="Save_Click"/>
    </StackPanel>
  </Grid>
</Window>
